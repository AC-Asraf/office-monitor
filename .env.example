# Office Monitor Configuration
# Copy this file to .env and fill in your values

# ===========================================
# SERVER SETTINGS
# ===========================================
PORT=3002
NODE_ENV=production

# ===========================================
# ZOOM API INTEGRATION
# ===========================================
# Get these from: https://marketplace.zoom.us/develop/create
# Required for Zoom Room status monitoring
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here

# ===========================================
# POLY LENS INTEGRATION
# ===========================================
# Get these from: https://lens.poly.com/developer
# Required for Poly device monitoring
POLY_LENS_CLIENT_ID=your_client_id_here
POLY_LENS_CLIENT_SECRET=your_client_secret_here

# ===========================================
# SLACK INTEGRATION
# ===========================================
# Webhook for alert notifications
# Get this from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#your-alerts-channel

# Bot token for 2FA approval requests (optional)
# Create a Slack app with chat:write scope
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_ADMIN_USER_ID=U00000000

# ===========================================
# MONITORING SETTINGS
# ===========================================
CHECK_INTERVAL=30000    # Check interval in milliseconds (default: 30 seconds)
PING_TIMEOUT=5000       # Ping timeout in milliseconds (default: 5 seconds)

# ===========================================
# SECURITY SETTINGS
# ===========================================
# Default admin account (created on first run)
# IMPORTANT: Change these values before first run!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123

# Session settings
SESSION_INACTIVITY_TIMEOUT=1800000  # 30 minutes in ms

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=./logs/audit.log
